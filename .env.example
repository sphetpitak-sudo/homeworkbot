# ── Required ──
# Get Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# Notion Integration Token + Database ID
# Create an integration at https://www.notion.so/my-integrations
NOTION_TOKEN=
DATABASE_ID=

# ── Required for AI parsing + Q&A ──
# Free API key at https://playground.opentyphoon.ai/settings/api-key
# Uses typhoon-v2.5-30b (free: 5 req/s, 200 req/min)
# Without this, falls back to regex-based parsing
TYPHOON_API_KEY=

# ── Optional: Web Dashboard URL ──
# Shows 🌐 button in bot menu. e.g. https://your-app.onrender.com
WEB_URL=

# ── Optional: Web Dashboard Auth ──
# Generate with: openssl rand -hex 32
# If not set, dashboard has no auth (anyone with the URL can access)
DASHBOARD_TOKEN=

# ── Optional: Server ──
# Server port (default: 8080)
PORT=8080

# ── Optional: Timezone ──
# Used by cron jobs and date display (default: Asia/Bangkok)
TZ=Asia/Bangkok

# ── Optional: Reminder Chat ──
# Telegram chat ID for automatic daily reminders
# Send reminders about upcoming/overdue homework to this chat/group/channel
REMINDER_CHAT_ID=
