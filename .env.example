# ── Required ──
TELEGRAM_TOKEN=
NOTION_TOKEN=
DATABASE_ID=

# ── Required for AI parsing + Q&A ──
# Get free API key at https://playground.opentyphoon.ai/settings/api-key
# Uses typhoon-v2.5-30b, free limit: 5 req/s, 200 req/min
TYPHOON_API_KEY=

# ── Optional: Web Dashboard URL ──
# Shows 🌐 button in bot menu. e.g. https://your-app.com/?token=DASHBOARD_TOKEN
WEB_URL=

# ── Optional: Web Dashboard Auth ──
# Secret token for the web dashboard (generate with: openssl rand -hex 32)
# If not set, derived from SHA256(NOTION_TOKEN)
DASHBOARD_TOKEN=your_dashboard_token_here

# ── Optional: Timezone ──
# Used by cron jobs and date display
TZ=Asia/Bangkok

# ── Optional: Reminder ──
REMINDER_CHAT_ID=
